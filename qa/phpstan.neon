# PHPStan gate — level 5 (MIG-09 ratchet; the H5 exit target. History:
# L0 Stabilize -> L2+51-error baseline MIG-03 -> L5 empty-baseline here).
# L8 + strict types is the MIG-10 finish line (see the Ptah ledger,
# projects/guestbook2/infra/qa-gates.yml). The CI3-idiom baseline died with
# the CI4 port — ported code carries no ignore list.
parameters:
    level: 5
    bootstrapFiles:
        - phpstan-bootstrap.php
    scanFiles:
        - %currentWorkingDirectory%/vendor/codeigniter4/framework/system/Common.php
        - %currentWorkingDirectory%/app/Common.php
    paths:
        - %currentWorkingDirectory%/app/Controllers
        - %currentWorkingDirectory%/app/Repositories
        - %currentWorkingDirectory%/tests
    excludePaths:
        - %currentWorkingDirectory%/tests/_support/*
