{
	"name": "ptah/guestbook2",
	"description": "Guestbook on CodeIgniter 4 (PTAH Modernize H5 port)",
	"license": "MIT",
	"type": "project",
	"require": {
		"php": "^8.1",
		"codeigniter4/framework": "~4.7.0"
	},
	"require-dev": {
		"deptrac/deptrac": "3.0.0",
		"kint-php/kint": "^6.1",
		"phpstan/phpstan": "^1.12",
		"phpstan/phpstan-strict-rules": "^1.6",
		"phpunit/phpunit": "^10.5.16"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Config\\": "app/Config/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"platform": {
			"php": "8.4.8"
		},
		"preferred-install": "dist",
		"sort-packages": true
	},
	"scripts": {
		"test": "phpunit"
	}
}
