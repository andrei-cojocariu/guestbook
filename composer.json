{
	"name": "ptah/guestbook2",
	"description": "Guestbook on CodeIgniter 4 (PTAH Modernize H5 port)",
	"license": "MIT",
	"type": "project",
	"require": {
		"php": "^8.1",
		"codeigniter4/framework": "~4.6.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5.16"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Config\\": "app/Config/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"platform": {
			"php": "8.1.32"
		},
		"preferred-install": "dist",
		"sort-packages": true
	},
	"scripts": {
		"test": "phpunit"
	}
}
