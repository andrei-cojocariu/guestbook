<?xml version="1.0" encoding="UTF-8"?>
<!--
  tsk-003 characterization net, ported to PHPUnit 9.6 (PTAH MIG-03, hop H2).

  Consumed by `hooks.test` (.ptah/ptah.yaml): `php vendor/bin/phpunit` runs
  inside the app container (PHPUnit 9.6 phar + PCOV coverage driver, see
  Dockerfile). DEBT-8's PHP 5.6/PHPUnit 5.7 ceiling was retired by MIG-02/03.
  The convert* attributes are kept deliberately: notices/warnings still fail
  the characterization suite, same semantics as the original net.

  The "unit" testsuite stays pointed at the single `<file>`
  `GuestbookRepositoryContractTest.php`: `application/tests/unit` also holds
  `GuestbookRepositoryPortTest.php`, a standalone PHPUnit-free script
  (procedural, calls `exit()`) that a `<directory suffix="Test.php">` glob
  would require and thereby abort the whole run.

  <coverage> drives `- -coverage-text` for the ratcheted coverage gate
  (infra/qa-gates.yml in the Ptah ledger): owned application/ code only,
  tests excluded.
-->
<phpunit bootstrap="application/tests/characterization/bootstrap.php"
         colors="false"
         stopOnFailure="false"
         convertErrorsToExceptions="true"
         convertNoticesToExceptions="true"
         convertWarningsToExceptions="true">
    <testsuites>
        <testsuite name="characterization">
            <directory suffix="Test.php">application/tests/characterization</directory>
        </testsuite>
        <testsuite name="unit">
            <file>application/tests/unit/GuestbookRepositoryContractTest.php</file>
        </testsuite>
    </testsuites>
    <coverage>
        <include>
            <directory suffix=".php">application</directory>
        </include>
        <exclude>
            <directory>application/tests</directory>
            <directory>application/views/errors</directory>
        </exclude>
    </coverage>
</phpunit>
