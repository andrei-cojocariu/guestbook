<?xml version="1.0" encoding="UTF-8"?>
<!--
  Characterization + unit net, ported to CI4 / PHPUnit 10 (PTAH MIG-09,
  hop H5). Runs INSIDE the app container against the SAME live MySQL the app
  serves from: `php vendor/bin/phpunit` (hooks.test unchanged).

  Feature tests exercise the full framework in-process (FeatureTestTrait),
  which is what finally makes the line-coverage gate meaningful — the CI3-era
  suite drove a separate php -S process, invisible to the coverage driver.

  <source> scopes coverage to the OWNED domain surface (controller,
  repositories, views); app/Config is generated framework scaffolding and
  app/Views/errors ships with the appstarter.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/codeigniter4/framework/system/Test/bootstrap.php"
         colors="false"
         cacheDirectory="writable/.phpunit.cache"
         failOnWarning="true">
    <testsuites>
        <testsuite name="feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">app/Controllers</directory>
            <directory suffix=".php">app/Repositories</directory>
            <directory suffix=".php">app/Views</directory>
        </include>
        <exclude>
            <directory>app/Views/errors</directory>
        </exclude>
    </source>
    <php>
        <server name="app.baseURL" value="http://localhost:8080/"/>
        <server name="CI_ENVIRONMENT" value="testing"/>
    </php>
</phpunit>
