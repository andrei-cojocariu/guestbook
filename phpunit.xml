<!--
  tsk-003 characterization net.

  Consumed by `hooks.test` (.ptah/ptah.yaml): `php vendor/bin/phpunit` runs
  INSIDE the frozen `ci-guestbook:frozen` container (PHPUnit 5.7.27, the last
  PHPUnit 5.x release supporting PHP 5.6, see Dockerfile), so this file and
  every suite it points at must stay compatible with PHPUnit 5.7's XML schema
  (no PHPUnit 6+/9+ only attributes) and PHP 5.6 syntax (DEBT-8,
  .ptah/audit/legacy_debt.md).

  Presence of this file (plus vendor/bin/phpunit being executable) is exactly
  what flips hooks.test from its prior "PENDING, no suite wired yet" stub
  (see the tsk-002 fix, commit 76e7206) to actually invoking PHPUnit.

  tsk-007 (repository port, STR-1) adds the "unit" testsuite below, pointed
  at the single `<file>` `GuestbookRepositoryContractTest.php` rather than
  the whole `application/tests/unit` directory: that directory also holds
  `GuestbookRepositoryPortTest.php`, the software-developer-worker's own
  standalone, PHPUnit-free script (procedural body, calls `exit()` at the
  end) — it is explicitly documented as NOT wired into `hooks.test` and MUST
  NOT be swept in by a `<directory suffix="Test.php">` glob, which would
  `require` it and abort the whole PHPUnit run via its own `exit()` call.
  Reuses the characterization suite's own bootstrap (defines
  PTAH_CHARACTERIZATION_ROOT only) so both suites resolve the project root
  identically.
-->
<phpunit bootstrap="application/tests/characterization/bootstrap.php"
         colors="false"
         stopOnFailure="false"
         convertErrorsToExceptions="true"
         convertNoticesToExceptions="true"
         convertWarningsToExceptions="true">
    <testsuites>
        <testsuite name="characterization">
            <directory suffix="Test.php">application/tests/characterization</directory>
        </testsuite>
        <testsuite name="unit">
            <file>application/tests/unit/GuestbookRepositoryContractTest.php</file>
        </testsuite>
    </testsuites>
</phpunit>
