# Copy this file to `.env` (git-ignored — see .gitignore) and set a real
# value before running `docker compose up`. docker-compose.yml requires
# MYSQL_ROOT_PASSWORD (":?set MYSQL_ROOT_PASSWORD in .env" — compose fails
# fast if it is unset). NO real credential belongs in this example file.
MYSQL_ROOT_PASSWORD=

# --- CodeIgniter 4 (PTAH Modernize H5) --------------------------------------
# The app DB password is injected by docker-compose.yml from
# MYSQL_ROOT_PASSWORD above (env var database.default.password) — nothing
# more to set for local runs. In production, pin the public origin instead
# of trusting any request host (GB2 hardening):
# app.baseURL = 'https://guestbook.example.com/'
# CI_ENVIRONMENT = production
