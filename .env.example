# Copy this file to `.env` (git-ignored — see .gitignore) and set a real
# value before running `docker compose up`. docker-compose.yml requires
# MYSQL_ROOT_PASSWORD (":?set MYSQL_ROOT_PASSWORD in .env" — compose fails
# fast if it is unset). NO real credential belongs in this example file.
MYSQL_ROOT_PASSWORD=

# --- tsk-004 (Seam 4, SEC-2/SEC-3/SEC-5): application/config/database.php +
# config.php read every value below via getenv(). docker-compose.yml's `app`
# service loads this file via `env_file:`, so populating it here is enough
# for a plain `docker compose up` — no code change and no rebuild needed to
# rotate a value. Every entry is OPTIONAL: application/config/database.php /
# config.php fall back to a non-secret, non-functional local-dev default
# (never the former committed literal) when a key is left blank/absent, so
# the app still boots without this section filled in. Only set real
# secrets locally in `.env` itself — this example file must stay blank.
#
#   DB_HOSTNAME    - MySQL host (default: 'localhost' — the frozen
#                    container's same-host mysqli socket topology, tsk-002)
#   DB_USERNAME    - MySQL user (default: 'root', local dev only)
#   DB_PASSWORD    - MySQL password (default: '' — fails closed, never the
#                    purged 'Start123!' literal)
#   DB_DATABASE    - schema name (default: 'guestbook')
#   ENCRYPTION_KEY - CI's $config['encryption_key'] (default: '' — fails
#                    closed, never the purged literal; generate a real key
#                    with `docker compose run --rm app php -r
#                    "echo bin2hex(random_bytes(16));"` for anything beyond
#                    local dev)
#   CI_ENV         - resolves CodeIgniter's ENVIRONMENT constant
#                    (index.php:56); 'development' | 'testing' | 'production'.
#                    Unset defaults to 'development'. MUST be 'production' in
#                    any real deploy so db_debug resolves FALSE (SEC-5).
DB_HOSTNAME=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
ENCRYPTION_KEY=
CI_ENV=
